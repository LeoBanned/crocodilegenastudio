{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crocodile Gena Studio",
  "version": "3.2.3",
  "identifier": "studio.crocodilegena.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Crocodile Gena Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": false,
        "backgroundColor": "#07090e",
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "Premium Steam and EOS utility workspace",
    "icon": ["icon.ico"],
    "resources": {
      "../backend/core_engine/": "backend/core_engine/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MjVCOUEzMzM0NUFGNzYKUldSMnIwVXpvN2tsMVRCNWtxMHh5aVhadEFYOXNRMktlYS81SHNzc05BaXAxM2NObkU0cjZTdmIK",
      "endpoints": [
        "https://github.com/LeoBanned/crocodilegenastudio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
